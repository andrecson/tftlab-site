# Postgres connection string used by Prisma (see prisma/schema.prisma).
# Copy this file to .env and adjust the credentials for your environment.
# On Neon/serverless (Vercel), set this to the POOLED connection string.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/metacomps?schema=public"
# Direct (non-pooled) URL used only by migrations (`prisma migrate deploy`).
# Vercel's Neon integration injects this automatically (DATABASE_URL_UNPOOLED);
# locally it's the same as DATABASE_URL.
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/metacomps?schema=public"

# Canonical public origin used for SEO: metadataBase, canonical URLs, sitemap,
# robots.txt and Open Graph tags (see src/lib/site.ts). No trailing slash.
# Defaults to the production domain when unset. On a hidden/test deploy set this
# to the test URL (e.g. the *.vercel.app URL or a teste.tftlab.com.br subdomain).
NEXT_PUBLIC_SITE_URL="https://tftlab.com.br"

# Hidden/TEST deploy switch. Set to "true" to block search indexing entirely
# (robots.txt disallows all + a noindex meta on every page), so a test deploy
# never competes with the live tftlab.com.br. Leave unset/false in production.
NEXT_PUBLIC_NOINDEX=""

# --- Pagamento (integração com o bot de assinaturas / Discord) ---------------
# URL pública do bot (discord-stripe-bot) na VPS. O site chama
# ${NEXT_PUBLIC_BOT_URL}/api/mercadopago/preferences/create para o checkout do
# Mercado Pago. Ex.: https://pagamento.tftlab.com.br . Vazio = cai no WhatsApp.
NEXT_PUBLIC_BOT_URL=""
# Stripe Payment Links (um por plano), criados no painel da Stripe.
NEXT_PUBLIC_STRIPE_LINK_MONTH=""
NEXT_PUBLIC_STRIPE_LINK_YEAR=""

# Auth.js / NextAuth admin authentication (see src/auth.ts, US-030).
# AUTH_SECRET signs the session JWT — generate one with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-string"
# Trust the incoming Host header when not deployed behind Vercel (needed for
# local dev / self-hosting). Leave as true unless you terminate TLS elsewhere.
AUTH_TRUST_HOST="true"

# Seed credentials for the initial ADMIN curator (prisma/seed.ts upserts this
# user). Change the password before any real deployment.
ADMIN_EMAIL="admin@metacomps.gg"
ADMIN_PASSWORD="admin1234"

# Seed credentials for the shared EDITOR curator login (US-045). The identifier
# can be a plain username (not an e-mail) and is stored in the unique `email`
# column. Defaults to a simple internal tftlab/tftlab login — change or move to
# a strong password before any real deployment.
CURATOR_EMAIL="tftlab"
CURATOR_PASSWORD="tftlab"

# Analytics (US-041) — privacy-friendly, cookieless pageviews + events (Plausible
# by default). Leave NEXT_PUBLIC_ANALYTICS_DOMAIN unset to fully disable analytics
# (no script loaded, no consent banner). Set it to the site domain registered in
# your Plausible dashboard to enable it.
NEXT_PUBLIC_ANALYTICS_DOMAIN=""
# Optional: override the analytics script source (self-hosted Plausible / proxy).
# Defaults to Plausible's manual-pageview script.
NEXT_PUBLIC_ANALYTICS_SRC="https://plausible.io/js/script.manual.js"

# Error monitoring (US-041) — client errors captured by the app's error
# boundaries + global listeners and, in production only, POSTed as JSON to this
# endpoint. Point it at your Sentry DSN (or any collector); leave unset to
# disable reporting.
NEXT_PUBLIC_SENTRY_DSN=""
# Optional generic error-reporting endpoint (takes precedence over the DSN).
NEXT_PUBLIC_ERROR_REPORTING_URL=""
